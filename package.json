{
  "name": "zundamonotify",
  "version": "1.0.0",
  "description": "AIエージェントのお仕事完了を「ずんだもん」の音声でお知らせするCLIツールなのだ",
  "type": "module",
  "bin": {
    "zundamonotify": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "stop": "node bin/cli.js stop",
    "hook": "node bin/cli.js init -f",
    "hook:show": "node bin/cli.js init",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "license": "MIT"
}
